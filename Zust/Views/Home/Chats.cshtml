@using Microsoft.AspNetCore.Identity;
@using Zust.Entities.Models;
@using Zust.Web.Helpers.ConstantHelpers;
@{
    var userManager = Context.RequestServices.GetService<UserManager<User>>();
    var user = await userManager.GetUserAsync(Context.User);
    ViewData["Title"] = "Zust - Chats";
}

<style>
    #container {
        margin-top: 0px;
        margin-bottom: 0px;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%; /* hold full width immediately, before any chats load */
        /* Span the full content area (not capped at 850px) and, via fillToViewportHeight(),
           stretch to the bottom of the viewport so the white card stays full width + height
           even when there are no chats. */
        max-width: none;
    }

    /* The list holder fills the container (capped for readability) and keeps its
       width even while empty, so the layout doesn't shift once chats arrive. */
    #my-chats {
        width: 100%;
        max-width: 600px;
        min-height: 1px;
    }

    .item {
        width: 100%;
        padding-bottom: 10px;
        cursor: pointer;
    }

    /* Reserve the avatar's space and show a neutral placeholder immediately, so rows
       don't visibly pop in one by one as each remote image finishes downloading. */
    .item .figure img {
        height: 70px;
        width: 70px;
        object-fit: cover;
        background-color: #e2e6ea;
    }

    .custom-spinner-color {
        color: var(--main-color);
    }

    #spinner {
        margin: auto;
        margin-top: 10px;
    }
</style>


<div class="all-notifications-body" id="container">

    <div class="all-notifications-header d-flex justify-content-between align-items-center">
        <h3 class="text-center w-100">Chats</h3>
    </div>

    <div id="my-chats">
    </div>

    <div id="spinner" class="spinner-border custom-spinner-color" role="status">
        <span class="sr-only"></span>
    </div>
</div>


<script src="~/assets/js/jquery.min.js"></script>
<script src="~/assets/js/functions.js"></script>
<!-- Add an empty div with the ID "my-chats" where the user chats will be displayed -->

<script>
    localStorage.setItem('activeMenuItem', '#6');

    var currentUserId = '@user.Id.ToString()';

    function startSpinner() {
        $('#spinner').css("visibility", "visible");
    }

    function stopSpinner() {
        $('#spinner').css("visibility", "hidden");
    }

    var createUserChatHtml = function (chat) {
        var content = `
                <div class="item d-flex justify-content-between align-items-center" onclick=redirectToChat('${chat.id}')>
                    <div class="figure">
                        <a href="/home/chats?userId=${chat.id}"><img src="${chat.imageUrl}" class="rounded-circle" alt="image"></a>
                    </div>
                    <div class="text">
                        <h4><a href="/home/chats?userId=${chat.id}">${chat.userName}</a></h4>
                        <span>${chat.lastMessage}</span>
                    </div>
                </div>
                    <hr \>
            `;
        return content;
    };

    function redirectToChat(userId){
        window.location.href = `/home/chats?userId=${userId}`;
    }

    async function getUserChats() {
        try {
            // Fetch the whole chat list (each partner plus their last message) in a single
            // request, then render it all at once. Previously the page fetched the chat list
            // and then issued a separate GetLastMessage request per chat, so the browser's
            // per-host connection limit made the chats trickle in one by one.
            var chatList = await makeAjaxRequest(`/api/Chat/GetChatList?userId=${currentUserId}`, "GET");

            var chats = document.getElementById("my-chats");

            if (!chatList || chatList.length === 0) {
                chats.innerHTML = getNoResultHtml("No Chats", "You have no conversations yet.");
                return;
            }

            chats.innerHTML = chatList.map(createUserChatHtml).join('');
        } catch (error) {
            console.error("Error fetching user chats:", error);
        } finally {
            // Hide the spinner once the whole list is rendered, so chats appear all at
            // once (like the Friend Requests page) rather than the page sitting on an
            // empty box while loading.
            stopSpinner();
        }
    }

    fillToViewportHeight(document.getElementById("container"), 30);
    startSpinner();
    getUserChats();

</script>
