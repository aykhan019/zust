    <!-- SignalR + shared connection, loaded on every page so real-time notification sounds and
         badge updates work app-wide (not only on the few pages that wire SignalR themselves). -->
    <script src="~/assets/js/signalr/dist/browser/signalr.js"></script>
    <script src="~/assets/js/userHub.js"></script>
    <script>
        // Global real-time handlers, active on every page. Page-specific scripts still register
        // their own handlers on the same shared `connection` for their DOM updates; here we only
        // play the notification sound and keep the navbar badge counts live. playNotificationSound
        // is throttled, so the paired events the server emits for one action never double-chime.
        (function () {
            function setBadgeCount(type, value) {
                var n = parseInt(value, 10);
                var count = isNaN(n) || n < 0 ? 0 : n;
                document.querySelectorAll('[data-badge-type="' + type + '"]').forEach(function (el) {
                    el.innerHTML = count > 99 ? "99+" : count;
                    el.classList.toggle("is-empty", count === 0);
                    el.setAttribute("aria-label", count + " new " + type.replace("-", " "));
                });
            }

            function bumpBadge(type, delta) {
                var firstBadge = document.querySelector('[data-badge-type="' + type + '"]');
                var current = firstBadge ? parseInt(firstBadge.innerHTML, 10) : 0;
                setBadgeCount(type, (isNaN(current) ? 0 : current) + delta);
            }

            window.setRealtimeBadgeCount = setBadgeCount;
            window.bumpRealtimeBadge = bumpBadge;

            if (typeof connection === "undefined" || !connection) {
                return;
            }

            // New notification (comments, friend-request accept/decline, generic notifications).
            connection.on("ReceiveNotification", function () {
                playNotificationSound();
                bumpBadge("notifications", 1);
            });

            // Incoming friend request.
            connection.on("ReceiveFriendRequest", function () {
                playNotificationSound();
                bumpBadge("friend-requests", 1);
            });

            // Someone responded to a friend request you sent (no badge change here; the
            // accompanying ReceiveNotification already covers the sound + notification badge).
            connection.on("ReceiveFriendRequestResponse", function () {
                playNotificationSound();
            });

            // Incoming chat message — softer single-note tone.
            connection.on("ReceiveMessage", function () {
                playNotificationSound("message");
                bumpBadge("messages", 1);
            });
        })();
    </script>
</body>
</html>

<script>
    var currentUserId = '@user.Id.ToString()';

    async function setData(){
        var friendRequestCount = await makeAjaxRequest("/api/FriendRequest/GetPendingReceivedFriendRequestsCount?userId=" + currentUserId, "GET");
        var notificationCount = await makeAjaxRequest("/api/Notification/GetUnreadNotificationCount?userId=" + currentUserId, "GET");
        window.setRealtimeBadgeCount("friend-requests", friendRequestCount);
        window.setRealtimeBadgeCount("notifications", notificationCount);
        window.setRealtimeBadgeCount("messages", 0);
    }

    setData();

    var chats = document.getElementById("chats");

    var createChatHtml = function(user) {
        var content = `
            <div class="chat-item">
                <a href="/home/chats?userId=${user.id}"><img src="${user.imageUrl}" class="rounded-circle myimg" alt="image"></a>
                <span class="name"><a href="/home/chats?userId=${user.id}" title="${user.userName}">${user.userName}</a></span>
            </div>
        `;
        return content;
    };

    async function getChats() {
        var users = await makeAjaxRequest(`/api/Chat/GetChats?userId=${currentUserId}`, "GET");
        if (users != null){
            users.forEach(user => {
                if (!user) {
                    return; // skip null entries (chat partner with no matching account)
                }
                chats.innerHTML += createChatHtml(user);
            });
        }
        else{
            chats.innerHTML = 'There is not chat';
        }
    }

    async function setChats() {
        await getChats();
    }

    setChats();

    function getSpecialUsers() {
        return new Promise(function (resolve, reject) {
            $.ajax({
                url: '/api/Static/GetSpecialUsers',
                type: 'GET',
                success: function (response) {
                    resolve(response);
                },
                error: function (error) {
                    reject(new Error(error && error.responseText ? error.responseText : "Failed to load special users"));
                }
            });
        });
    }

    function createSpecialUserHtml(specialUser) {
        var redirectPage = '';
        if (specialUser.id == currentUserId){
            redirectPage = '/home/my-profile';
        }
        else{
            redirectPage = '/home/users?id=' + specialUser.id;
        }

        var content = `
          <div class="contact-item">
            <a href="${redirectPage}">
              <img src="${specialUser.imageUrl}" class="rounded-circle" alt="image">
            </a>
            <span class="name">
              <a href="${redirectPage}" title="${specialUser.userName}">${specialUser.userName}</a>
            </span>
          </div>`;
        return content;

    }

    async function setSpecialUsers() {
        var specialUsers = await getSpecialUsers();
        var container = document.getElementById("special-users");
        if (specialUsers != null && specialUsers.length > 0) {
            var htmlContainer = '';
            for (var i = 0; i < specialUsers.length; i++) {
                var specialUser = specialUsers[i];
                if (!specialUser) {
                    continue; // skip null entries (special-user id with no matching account)
                }
                htmlContainer += createSpecialUserHtml(specialUser);
            }
            container.innerHTML = htmlContainer;
        }
        else {
            container.style.color = 'red';
            container.innerHTML += "No special users";
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        setSpecialUsers();

        var navLinks = document.querySelectorAll('.nav-item');

        var activeItem = localStorage.getItem('activeMenuItem');

        // If an active menu item is found, add the "active" class to it.
        // Guard every lookup: the stored id may be missing, non-numeric, or point at an
        // element that does not exist on the current page (this script runs on every page).
        if (activeItem) {
            navLinks.forEach(i => {
                i.classList.remove('active');
            });
            var activeId = activeItem.replace("#", "");
            var activeEl = activeId ? document.getElementById(activeId) : null;
            if (activeEl) {
                activeEl.classList.add("active");
            }
            if (navLinks.length > 0 && navLinks[0].id) {
                localStorage.setItem('activeMenuItem', '#' + navLinks[0].id);
            }
        }

        navLinks.forEach(function (link) {
            link.addEventListener('click', function (event) {
                navLinks.forEach(function (link) {
                    link.classList.remove('active');
                });

                this.classList.add('active');

                localStorage.setItem('activeMenuItem', '#' + this.id);
            });
        });
    });



</script>
